# ============================================
# Supabase — copia este archivo a .env y completa
# https://app.supabase.com/project/_/settings/api
# ============================================
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# URL pública del sitio para auth redirects (importante en producción)
VITE_PUBLIC_SITE_URL=https://app.quiropraxiadiaz.co

# ============================================
# SOLO PARA SCRIPTS DE OPS (no se incluye en el bundle frontend)
# ============================================
SUPABASE_DB_URL=postgresql://postgres.your-project-ref:YOUR_PASSWORD@aws-1-us-east-1.pooler.supabase.com:5432/postgres

# ============================================
# Configuración del consultorio (landing pública)
# Todas son opcionales — hay defaults razonables.
# ============================================
VITE_CLINIC_NAME=Quiropraxia Díaz
VITE_CLINIC_DOCTOR=Dr. Miguel Ángel Díaz
VITE_CLINIC_PHONE=+573112345678
VITE_CLINIC_PHONE_DISPLAY=+57 311 234 5678
VITE_CLINIC_EMAIL=contacto@quiropraxiadiaz.co
VITE_CLINIC_ADDRESS=Calle 100 # 15-45, Consultorio 502
VITE_CLINIC_ADDRESS_2=Edificio Clínica de la Salud
VITE_CLINIC_CITY=Bogotá, Colombia
VITE_CLINIC_HOURS_WEEKDAYS=Lun - Vie: 8:00 AM - 6:00 PM
VITE_CLINIC_HOURS_SATURDAY=Sáb: 8:00 AM - 1:00 PM
