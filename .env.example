VITE_CLINIC_ADDRESS=Calle 100 # 15-45, Consultorio 502
VITE_CLINIC_ADDRESS_2=Edificio Clínica de la Salud
VITE_CLINIC_CITY=Bogotá, Colombia
VITE_CLINIC_HOURS_WEEKDAYS=Lun - Vie: 8:00 AM - 6:00 PM
VITE_CLINIC_HOURS_SATURDAY=Sáb: 8:00 AM - 1:00 PM
