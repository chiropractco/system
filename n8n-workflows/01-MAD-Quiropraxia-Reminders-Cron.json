    "¿Saltar?": { "main": [[], [{ "node": "Upsert conversation", "type": "main", "index": 0 }]] },
    "Upsert conversation": { "main": [[{ "node": "Enviar WhatsApp", "type": "main", "index": 0 }]] },
    "Enviar WhatsApp": { "main": [[{ "node": "Marcar como enviado", "type": "main", "index": 0 }]] },
    "Marcar como enviado": { "main": [[{ "node": "Loggear mensaje", "type": "main", "index": 0 }]] }
  },
  "settings": { "executionOrder": "v1", "timezone": "America/Bogota" },
